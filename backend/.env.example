DATABASE_URL=postgresql://user:pass@host.neon.tech/neondb?sslmode=require
JWT_SECRET=change-me-use-openssl-rand-base64-32
# Local Postgres (no Docker), e.g. after: createdb quikinspect
# DATABASE_URL=postgresql://YOUR_MAC_USERNAME@127.0.0.1:5432/quikinspect
# Optional:
# JWT_EXPIRES_IN=7d
# CORS_ORIGIN=*
# RUN_MIGRATIONS_ON_STARTUP=false
# After adding a new migrations/*.sql on an existing DB, run once: FORCE_RUN_ALL_MIGRATIONS=1
# or: python scripts/migrate.py
