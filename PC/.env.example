# Copy this file to ".env" in the same folder (PC/) and adjust values.
# Restart Expo after changing env vars (stop Metro, run npm start again).

# ---------------------------------------------------------------------------
# EXPO_PUBLIC_* = baked into the app at bundle time — NOT secret.
# Do not put passwords, DB URLs, or private keys here.
# ---------------------------------------------------------------------------

# API base URL (Express): no trailing slash, no "/auth" path.
#
# Deployed API (Expo Go / TestFlight / production builds):
#   EXPO_PUBLIC_API_URL=https://pc-server-one.vercel.app
#
# iOS Simulator on the same Mac as the API:
#   EXPO_PUBLIC_API_URL=http://127.0.0.1:3000
#
# Physical phone on the same Wi‑Fi as your Mac (API running on the Mac):
#   EXPO_PUBLIC_API_URL=http://192.168.x.x:3000
#   Use your Mac's LAN IP (System Settings → Network), not "localhost"
#   (localhost on the phone is the phone itself).
#
# EXPO_PUBLIC_API_URL=https://pc-server-one.vercel.app

# ---------------------------------------------------------------------------
# Metro / Expo Go — "public URL" for loading the JavaScript bundle
# ---------------------------------------------------------------------------
# Default "npm start" / "npm run start:lan" → LAN URL (phone must be on same
#   Wi‑Fi as the computer running Metro).
# "npm run start:tunnel" → public https://… tunnel (works off-Wi‑Fi / strict
#   networks). First run may ask you to log in to Expo for tunneling.
# This is separate from EXPO_PUBLIC_API_URL (your REST API).

# ---------------------------------------------------------------------------
# EAS production builds (optional overrides — set in EAS Secrets or CI)
# ---------------------------------------------------------------------------
# IOS_BUNDLE_ID=com.yourorg.quikinspect
# ANDROID_PACKAGE=com.yourorg.quikinspect
