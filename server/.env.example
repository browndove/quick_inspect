# Neon — Dashboard → Connection string (pooler recommended).
# If the dashboard adds `channel_binding=require`, remove it for Vercel/serverless
# (it can cause long hangs / 504). Keep `sslmode=require`.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string

JWT_EXPIRES_IN=7d

# Local Node only (ignored on Vercel; Vercel sets PORT)
PORT=3000

# Bind address for local dev (0.0.0.0 = reachable from LAN). Vercel ignores this.
HOST=0.0.0.0

# production | development — Vercel sets production automatically
# NODE_ENV=production

# Optional: comma-separated web origins for CORS (Expo web, admin site).
# Native Expo apps often send no Origin — those still work with a list set.
# Leave unset or use * for permissive mode.
# CORS_ORIGIN=https://your-app.expo.dev,https://yourdomain.com
